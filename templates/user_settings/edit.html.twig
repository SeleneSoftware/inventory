{% extends 'base.dashboard.html.twig' %}

{% block title %}Edit User: {{ user.getEmail }}{% endblock %}

    {% block main %}
        <section class="max-w-4xl p-6 mx-auto bg-white rounded-md shadow-md dark:bg-gray-800">
            <h2 class="text-lg font-semibold text-gray-700 capitalize dark:text-white">Edit User: {{ user.getEmail }}</h2>
            {{ form_start(form) }}

            {% for f in form %}
                {% if f.vars.name != '_token' %}
                    {% if f.vars.name == 'role' %}
                        <label for="{{ f.vars.id }}" class="flex items-center cursor-pointer group">
                            {#
                            We render the widget with 'sr-only peer' classes.
                            Symfony handles the 'checked', 'name', and 'id' attributes automatically.
                            #}
                            {{ form_widget(f, {
                            'attr': {
                            'class': 'sr-only peer'
                            }
                            }) }}

                            <div class="relative w-12 h-6 bg-white border border-gray-200 rounded-full
                                        dark:bg-gray-800 dark:border-gray-600
                                        peer-checked:bg-blue-600 peer-checked:border-transparent
                                        peer-focus:ring-2 peer-focus:ring-blue-300 peer-focus:ring-opacity-40
                                        transition-all duration-300 ease-in-out">

                                <div class="absolute left-1 top-1 w-4 h-4 bg-gray-700 dark:bg-gray-300 rounded-full
                                            transition-transform duration-300 ease-in-out
                                            peer-checked:translate-x-6 peer-checked:bg-white">
                                </div>
                            </div>

                            {# Render the label text if you want it displayed #}
                            {% if f.vars.label is not same as(false) %}
                                <span class="ml-3 text-gray-700 dark:text-gray-300 font-medium">
                                    {{ f.vars.label|trans }}
                                </span>
                            {% endif %}
                        </label>

                        {# Render errors if there are any #}
                        {{ form_errors(f) }}
                    {% else %}
                        <div class="grid grid-cols-1 gap-6 mt-4 sm:grid-cols-2">
                            {{ form_label(f,f.vars.label,{'label_attr': {'class': 'text-gray-700 dark:text-gray-200'}}) }}
                            {{ form_widget(f,{'attr': {'class': 'block w-full px-4 py-2 mt-2 text-gray-700 bg-white border border-gray-200 rounded-md dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 focus:border-blue-400 focus:ring-blue-300 focus:ring-opacity-40 dark:focus:border-blue-300 focus:outline-none focus:ring'}}) }}
                        </div>
                    {% endif %}
                {% endif %}
            {% endfor %}

            <div class="flex justify-end mt-6">
                <button class="px-8 py-2.5 leading-5 text-white transition-colors duration-300 transform bg-gray-700 rounded-md hover:bg-gray-600 focus:outline-none focus:bg-gray-600" type="submit">Save</button>
            </div>
            {{ form_end(form) }}
        </section>
    {% endblock %}
